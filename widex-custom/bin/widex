#!/usr/bin/env bash
set -euo pipefail

# Run the widex fork of codex (Rust) without interfering with the npm `codex`.
#
# - Official npm codex uses:   $HOME/.codex
# - Widex codex uses:          $HOME/.widex-codex
#
# This prevents config/schema mismatches from breaking the npm CLI.

SCRIPT_PATH="$(readlink -f -- "${BASH_SOURCE[0]}" 2>/dev/null || true)"
if [[ -z "${SCRIPT_PATH}" ]]; then
  SCRIPT_PATH="${BASH_SOURCE[0]}"
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/../.." && pwd)"

CODEX_HOME_DEFAULT="${HOME}/.widex-codex"

# Strict isolation: Widex should not inherit an existing CODEX_HOME (e.g. from the official `codex`)
# because that would "cross the streams" and pollute ~/.codex.
#
# If you really want to override Widex's CODEX_HOME, use WIDEX_CODEX_HOME explicitly.
if [[ -n "${CODEX_HOME:-}" && "${CODEX_HOME}" != "${CODEX_HOME_DEFAULT}" && -z "${WIDEX_CODEX_HOME:-}" ]]; then
  echo "widex: ignoring inherited CODEX_HOME='${CODEX_HOME}' and using '${CODEX_HOME_DEFAULT}'" >&2
fi
export CODEX_HOME="${WIDEX_CODEX_HOME:-${CODEX_HOME_DEFAULT}}"

# Codex canonicalizes CODEX_HOME when set, which requires the directory to exist.
# Create it up-front so a first-run `widex` doesn't fail.
mkdir -p -- "${CODEX_HOME}"

widex_default_root_settings() {
  cat <<'EOF'
model_provider = "custom"
model = "gpt-5.4"
model_reasoning_effort = "high"
disable_response_storage = true
personality = "pragmatic"
cli_auth_credentials_store = "file"
EOF
}

widex_default_custom_provider_block() {
  cat <<'EOF'
[model_providers.custom]
name = "custom"
wire_api = "responses"
requires_openai_auth = true
base_url = "https://api.wellau.com/v1"
EOF
}

widex_default_features_block() {
  cat <<'EOF'
[features]
apps = false
child_agents_md = true
codex_git_commit = true
js_repl = true
memories = true
multi_agent = true
prevent_idle_sleep = true
responses_websockets = true
responses_websockets_v2 = true
skill_env_var_dependency_prompt = true
sqlite = true
undo = true
EOF
}

widex_default_config_toml() {
  widex_default_root_settings
  printf '\n'
  widex_default_custom_provider_block
  printf '\n'
  widex_default_features_block
}

ensure_toml_table_defaults() {
  local config_path section_header defaults_text tmp_path
  config_path="$1"
  section_header="$2"
  defaults_text="$3"

  tmp_path="$(mktemp "${CODEX_HOME}/config.toml.table.XXXXXX")"

  awk \
    -v section_header="${section_header}" \
    -v defaults_text="${defaults_text}" '
    function trim(value) {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
      return value
    }

    function parse_key(line, parts, key) {
      split(line, parts, "=")
      if (length(parts) == 0) {
        return ""
      }
      key = trim(parts[1])
      return key
    }

    function flush_missing_defaults(    i, line, key) {
      if (!in_target_section || flushed_defaults) {
        return
      }
      for (i = 1; i <= defaults_count; i++) {
        line = defaults_lines[i]
        key = parse_key(line)
        if (!(key in seen_keys)) {
          print line
          changed = 1
        }
      }
      flushed_defaults = 1
    }

    BEGIN {
      defaults_count = split(defaults_text, raw_defaults, "\n")
      normalized_count = 0
      for (i = 1; i <= defaults_count; i++) {
        if (raw_defaults[i] == "") {
          continue
        }
        normalized_count++
        defaults_lines[normalized_count] = raw_defaults[i]
      }
      defaults_count = normalized_count
    }

    /^\[/ {
      flush_missing_defaults()
      in_target_section = ($0 == section_header)
      if (in_target_section) {
        flushed_defaults = 0
      }
      print
      next
    }

    {
      if (in_target_section && $0 !~ /^[[:space:]]*#/ && $0 ~ /=/) {
        seen_keys[parse_key($0)] = 1
      }
      print
    }

    END {
      flush_missing_defaults()
      if (!changed) {
        exit 3
      }
    }
  ' "${config_path}" > "${tmp_path}" || {
    local status=$?
    if [[ ${status} -eq 3 ]]; then
      rm -f -- "${tmp_path}"
      return 0
    fi
    rm -f -- "${tmp_path}"
    return "${status}"
  }

  mv -f -- "${tmp_path}" "${config_path}"
}

ensure_widex_default_config() {
  local config_path tmp_path
  config_path="${CODEX_HOME}/config.toml"

  if [[ ! -f "${config_path}" ]]; then
    widex_default_config_toml > "${config_path}"
    echo "widex: initialized ${config_path} with Widex defaults" >&2
    return 0
  fi

  local -a missing_root_settings=()

  if ! grep -Eq '^[[:space:]]*model_provider[[:space:]]*=' "${config_path}"; then
    missing_root_settings+=('model_provider = "custom"')
  fi
  if ! grep -Eq '^[[:space:]]*model[[:space:]]*=' "${config_path}"; then
    missing_root_settings+=('model = "gpt-5.4"')
  fi
  if ! grep -Eq '^[[:space:]]*model_reasoning_effort[[:space:]]*=' "${config_path}"; then
    missing_root_settings+=('model_reasoning_effort = "high"')
  fi
  if ! grep -Eq '^[[:space:]]*disable_response_storage[[:space:]]*=' "${config_path}"; then
    missing_root_settings+=('disable_response_storage = true')
  fi
  if ! grep -Eq '^[[:space:]]*personality[[:space:]]*=' "${config_path}"; then
    missing_root_settings+=('personality = "pragmatic"')
  fi
  if ! grep -Eq '^[[:space:]]*cli_auth_credentials_store[[:space:]]*=' "${config_path}"; then
    missing_root_settings+=('cli_auth_credentials_store = "file"')
  fi

  if (( ${#missing_root_settings[@]} > 0 )); then
    tmp_path="$(mktemp "${CODEX_HOME}/config.toml.root.XXXXXX")"
    for setting in "${missing_root_settings[@]}"; do
      printf '%s\n' "${setting}" >> "${tmp_path}"
    done
    printf '\n' >> "${tmp_path}"
    cat -- "${config_path}" >> "${tmp_path}"
    mv -f -- "${tmp_path}" "${config_path}"
    echo "widex: added missing Widex root defaults to ${config_path}" >&2
  fi

  if ! grep -Eq '^[[:space:]]*\[model_providers\.custom\][[:space:]]*$' "${config_path}"; then
    printf '\n' >> "${config_path}"
    widex_default_custom_provider_block >> "${config_path}"
    printf '\n' >> "${config_path}"
    echo "widex: added missing [model_providers.custom] to ${config_path}" >&2
  else
    ensure_toml_table_defaults \
      "${config_path}" \
      "[model_providers.custom]" \
      "$(widex_default_custom_provider_block | sed '1d')"
  fi

  if ! grep -Eq '^[[:space:]]*\[features\][[:space:]]*$' "${config_path}"; then
    printf '\n' >> "${config_path}"
    widex_default_features_block >> "${config_path}"
    printf '\n' >> "${config_path}"
    echo "widex: added missing [features] defaults to ${config_path}" >&2
  else
    ensure_toml_table_defaults \
      "${config_path}" \
      "[features]" \
      "$(widex_default_features_block | sed '1d')"
  fi
}

migrate_widex_root_settings() {
  local config_path tmp_path backup_path
  config_path="${CODEX_HOME}/config.toml"

  if [[ ! -f "${config_path}" ]]; then
    return 0
  fi

  tmp_path="$(mktemp "${CODEX_HOME}/config.toml.root-migrate.XXXXXX")"

  awk '
    BEGIN {
      managed_keys[1] = "model_provider"
      managed_keys[2] = "model"
      managed_keys[3] = "model_reasoning_effort"
      managed_keys[4] = "disable_response_storage"
      managed_keys[5] = "personality"
      managed_keys[6] = "cli_auth_credentials_store"
      print "model_provider = \"custom\""
      print "model = \"gpt-5.4\""
      print "model_reasoning_effort = \"high\""
      print "disable_response_storage = true"
      print "personality = \"pragmatic\""
      print "cli_auth_credentials_store = \"file\""
    }

    /^\[/ {
      in_table = 1
      if (!printed_separator) {
        print ""
        printed_separator = 1
      }
      print
      next
    }

    {
      if (!in_table) {
        for (i = 1; i <= 6; i++) {
          key = managed_keys[i]
          if ($0 ~ "^[[:space:]]*" key "[[:space:]]*=") {
            next
          }
        }
        if (!printed_separator) {
          if ($0 ~ /^[[:space:]]*$/) {
            next
          }
          print ""
          printed_separator = 1
        }
      }
      print
    }
  ' "${config_path}" > "${tmp_path}"

  if cmp -s "${config_path}" "${tmp_path}"; then
    rm -f -- "${tmp_path}"
    return 0
  fi

  backup_path="${config_path}.pre-willau-defaults.bak"
  cp -f -- "${config_path}" "${backup_path}"
  mv -f -- "${tmp_path}" "${config_path}"
  echo "widex: normalized root Widex defaults in ${config_path}" >&2
  echo "widex: backup saved to ${backup_path}" >&2
}

#
# Keep old Widex-only provider definitions from breaking startup after we returned the
# mainline product path to upstream `responses` only.
#
# Historical user configs may still contain blocks like:
#   [model_providers.gemini-vectorengine]
#   wire_api = "gemini"
#
# Those legacy values should not prevent unrelated GPT/OpenAI sessions from resuming.
#
migrate_legacy_widex_config() {
  local config_path tmp_path backup_path
  config_path="${CODEX_HOME}/config.toml"

  if [[ ! -f "${config_path}" ]]; then
    return 0
  fi

  tmp_path="$(mktemp "${CODEX_HOME}/config.toml.migrate.XXXXXX")"

  awk '
    function is_legacy_provider(id) {
      return id ~ /^gemini([.-]|$)/ || id ~ /^grok-/
    }

    /^\[model_providers\./ {
      in_provider = 1
      provider_id = $0
      sub(/^\[model_providers\./, "", provider_id)
      sub(/\]$/, "", provider_id)
      sub(/^"/, "", provider_id)
      sub(/"$/, "", provider_id)
      sub(/\..*$/, "", provider_id)
      print
      next
    }

    /^\[/ {
      in_provider = 0
      provider_id = ""
      print
      next
    }

    {
      line = $0
      if (in_provider && is_legacy_provider(provider_id)) {
        sub(/wire_api[[:space:]]*=[[:space:]]*"gemini"/, "wire_api = \"responses\"", line)
        sub(/wire_api[[:space:]]*=[[:space:]]*"chat"/, "wire_api = \"responses\"", line)
      }
      print line
    }
  ' "${config_path}" > "${tmp_path}"

  if cmp -s "${config_path}" "${tmp_path}"; then
    rm -f -- "${tmp_path}"
    return 0
  fi

  backup_path="${config_path}.pre-mainline-wire-api.bak"
  cp -f -- "${config_path}" "${backup_path}"
  mv -f -- "${tmp_path}" "${config_path}"
  echo "widex: migrated legacy gemini/grok provider wire_api values in ${config_path}" >&2
  echo "widex: backup saved to ${backup_path}" >&2
}

migrate_widex_root_settings
migrate_legacy_widex_config
ensure_widex_default_config

# Brand-aware command hinting: within Widex, user-facing examples should prefer `widex ...`.
export WIDEX_CMD="${WIDEX_CMD:-widex}"

# Ensure subcomponents that spawn `codex exec` (e.g. ralph-widex) route back through the wrapper,
# so CODEX_HOME isolation stays consistent.
export CODEX_CMD="${CODEX_CMD:-${WIDEX_CMD}}"

BUILD_DIR="${REPO_ROOT}/codex-rs"

BUILD_PROFILE="${WIDEX_BUILD_PROFILE:-widex-release}"
BIN_PROFILE_DIR="${BUILD_PROFILE}"
if [[ "${BUILD_PROFILE}" == "upstream" || "${BUILD_PROFILE}" == "release" ]]; then
  # Use upstream release settings (fat LTO, single CGU, strip symbols).
  BUILD_PROFILE="release"
  BIN_PROFILE_DIR="release"
fi

BIN="${REPO_ROOT}/codex-rs/target/${BIN_PROFILE_DIR}/codex"

if [[ "${WIDEX_FORCE_REBUILD:-0}" == "1" ]]; then
  rm -f -- "${BIN}" 2>/dev/null || true
fi

if [[ ! -x "${BIN}" ]]; then
  if ! command -v cargo >/dev/null 2>&1; then
    echo "widex: missing release binary and cargo is not available on PATH." >&2
    echo "widex: install Rust (rustup) and rerun." >&2
    exit 1
  fi

  echo "widex: building Widex codex binary (profile: ${BUILD_PROFILE})..." >&2

  NPROC="$(getconf _NPROCESSORS_ONLN 2>/dev/null || true)"
  if [[ -z "${NPROC}" ]]; then
    NPROC="$(nproc 2>/dev/null || true)"
  fi
  if [[ -z "${NPROC}" ]]; then
    NPROC=8
  fi

  CARGO_JOBS="${WIDEX_CARGO_JOBS:-${NPROC}}"

  # Optional compiler cache for faster rebuilds.
  if [[ "${WIDEX_USE_SCCACHE:-0}" == "1" ]] && command -v sccache >/dev/null 2>&1; then
    export RUSTC_WRAPPER="sccache"
  fi

  if [[ "${BUILD_PROFILE}" == "release" ]]; then
    (cd "${BUILD_DIR}" && CARGO_BUILD_JOBS="${CARGO_JOBS}" cargo build -p codex-cli --bin codex --release)
  else
    (cd "${BUILD_DIR}" && CARGO_BUILD_JOBS="${CARGO_JOBS}" cargo build -p codex-cli --bin codex --profile "${BUILD_PROFILE}")
  fi
fi

if [[ -x "${BIN}" ]]; then
  # Make `--help`/usage strings show `widex` instead of the underlying `codex` binary name.
  exec -a "${WIDEX_CMD}" "${BIN}" "$@"
else
  echo "widex: expected binary at ${BIN}, but it is missing or not executable." >&2
  exit 1
fi
