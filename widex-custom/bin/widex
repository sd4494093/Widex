#!/usr/bin/env bash
set -euo pipefail

# Run the widex fork of codex (Rust) without interfering with the npm `codex`.
#
# - Official npm codex uses:   $HOME/.codex
# - Widex codex uses:          $HOME/.widex-codex
#
# This prevents config/schema mismatches (e.g. wire_api = "gemini") from
# breaking the npm CLI.

SCRIPT_PATH="$(readlink -f -- "${BASH_SOURCE[0]}" 2>/dev/null || true)"
if [[ -z "${SCRIPT_PATH}" ]]; then
  SCRIPT_PATH="${BASH_SOURCE[0]}"
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/../.." && pwd)"

CODEX_HOME_DEFAULT="${HOME}/.widex-codex"
export CODEX_HOME="${CODEX_HOME:-${CODEX_HOME_DEFAULT}}"

# Hint the TUI switchover integration where to find the YAML.
export WIDEX_API_SWITCHER_CONFIG="${WIDEX_API_SWITCHER_CONFIG:-${CODEX_HOME}/api_switchover.yaml}"

BIN_RELEASE="${REPO_ROOT}/codex-rs/target/release/codex"
BUILD_DIR="${REPO_ROOT}/codex-rs"

if [[ ! -x "${BIN_RELEASE}" ]]; then
  if ! command -v cargo >/dev/null 2>&1; then
    echo "widex: missing release binary and cargo is not available on PATH." >&2
    echo "widex: install Rust (rustup) and rerun." >&2
    exit 1
  fi

  echo "widex: building release codex binary..." >&2
  (cd "${BUILD_DIR}" && cargo build -p codex-cli --bin codex --release)
fi

if [[ -x "${BIN_RELEASE}" ]]; then
  exec "${BIN_RELEASE}" "$@"
else
  echo "widex: expected release binary at ${BIN_RELEASE}, but it is missing or not executable." >&2
  exit 1
fi
